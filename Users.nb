                  RowBox[{"[", "2", "]"}], "]"}], ",", 
                 RowBox[{"flipColor", "[", 
                  RowBox[{"edge", "[", 
                   RowBox[{"[", "3", "]"}], "]"}], "]"}]}], "]"}]}]}], 
             "]"}]}]}], "]"}]}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Flip", " ", "both", " ", "direction", " ", "and", " ", "color"}],
     "*)"}], 
   RowBox[{
    RowBox[{"FlipandReverseColobluege", "[", 
     RowBox[{
      RowBox[{"CdGrf", "[", 
       RowBox[{"v_", ",", 
        RowBox[{"EList", "[", "edges___", "]"}]}], "]"}], ",", 
      "edge_CdEdge"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
