                RowBox[{"(", 
                 RowBox[{"CdEdge", "@@", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"#", "/.", " ", 
                    RowBox[{"{", 
                    RowBox[{"Rule", "->", "List"}], "}"}]}], "//", 
                    "Flatten"}], ")"}]}], ")"}]}], ")"}], "&"}], "/@", 
             RowBox[{"(", 
              RowBox[{"EList", "@@", "#"}], ")"}]}], ")"}], "&"}], ")"}], "/@",
          "edgelist"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"collect", " ", "vertices"}], "*)"}], 
       RowBox[{"vertlist", "=", 
