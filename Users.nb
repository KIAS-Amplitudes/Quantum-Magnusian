           RowBox[{"(*", 
            RowBox[{
            "Mark", " ", "the", " ", "current", " ", "graph", " ", "as", " ", 
             "processed", " ", "in", " ", "SetTable"}], "*)"}], 
           RowBox[{
            RowBox[{"SetTable", "[", 
             RowBox[{"ToCanon", "[", "A", "]"}], "]"}], "=", "0"}], ";"}], 
          ")"}]}], "]"}], ";"}]}], "]"}]}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Calculates", " ", "Omega", " ", "and", " ", "E", " ", "for", " ", "all", 
     " ", "graphs", " ", "up", " ", "to", " ", "size", " ", "n"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"CalculateWholeOmega", "[", "n_Integer", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "graphSet", "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Convert", " ", "skeleton", " ", "diagrams", " ", "to", " ", "Grf", " ",
         "format", " ", "for", " ", "graphs", " ", "up", " ", "to", " ", 
        "size", " ", "n"}], "*)"}], 
      RowBox[{
       RowBox[{"graphSet", "=", 
        RowBox[{"ConvertSkGrfToGrf", "[", 
         RowBox[{"SkeletonDiags", "[", "n", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Iterate", " ", "over", " ", "each", " ", "graph", " ", "in", " ", 
         "the", " ", "graph", " ", "set", " ", "and", " ", "process", " ", 
         "it", " ", "with", " ", "MainFunctionA"}], "*)"}], 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{"MainFunctionA", "[", 
          RowBox[{"graphSet", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "graphSet", "]"}]}], "}"}]}], "]"}], 
       ";"}]}], "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Function", " ", "to", " ", "calculate", " ", "Omega", " ", "and", " ", 
     "E", " ", "for", " ", "graphs", " ", "up", " ", "to", " ", "size", " ", 
     "n", " ", "and", " ", "store", " ", "the", " ", "results"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"OnlyCalculatingOmegaAndE", "[", "n_Integer", "]"}], ":=", 
    RowBox[{
     RowBox[{"OnlyCalculatingOmegaAndE", "[", "n", "]"}], "=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"time", ",", "result"}], "}"}], ",", 
       RowBox[{"(*", 
        RowBox[{
        "Measure", " ", "the", " ", "time", " ", "taken", " ", "to", " ", 
         "calculate", " ", "Omega", " ", "and", " ", "E", " ", "values"}], 
        "*)"}], 
       RowBox[{
        RowBox[{"result", "=", 
         RowBox[{"Do", "[", 
          RowBox[{
           RowBox[{"CalculateWholeOmega", "[", "i", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", 
             RowBox[{"Max", "[", 
              RowBox[{"2", ",", 
               RowBox[{"numbercounting", "+", "1"}]}], "]"}], ",", "n"}], 
            "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", "result"}]}], 
      "]"}]}]}], "\n"}]}]], "Input",
