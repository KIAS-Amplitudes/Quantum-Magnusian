Cell[BoxData[
 RowBox[{
  RowBox[{"FindCdGrfSymFactor", "[", "foo_CdGrf", "]"}], ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"Plus", "@@", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"foo", "===", "#"}], ",", "1", ",", "0"}], "]"}], "&"}], "/@", 
       RowBox[{"(", 
        RowBox[{"foo", "/.", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"Thread", "/@", 
                RowBox[{"Flatten", "@", 
                 RowBox[{"Outer", "[", 
                  RowBox[{"Rule", ",", 
                   RowBox[{"{", "#", "}"}], ",", 
                   RowBox[{"Permutations", "[", "#", "]"}], ",", "1"}], 
                  "]"}]}]}], ")"}], "&"}], "/@", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Last", "/@", 
                RowBox[{"SortCdGrfVertices", "[", "foo", "]"}]}], "/.", 
               RowBox[{"VList", "->", "List"}]}], " ", 
              RowBox[{"(*", " ", 
               RowBox[{
                RowBox[{"List", "[", "]"}], " ", "is", " ", "easier", " ", 
                "to", " ", "work", " ", "with", " ", "than", " ", 
                RowBox[{"VList", "[", "]"}]}], " ", "*)"}], " ", ")"}]}], 
            ")"}], "//", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"Flatten", "/@", 
              RowBox[{"Flatten", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"Outer", "[", 
                   RowBox[{"List", ",", 
                    RowBox[{"Sequence", "@@", "#"}], ",", "1"}], "]"}], "&"}],
                  "@", "#"}], ",", 
                RowBox[{
                 RowBox[{"Length", "[", "#", "]"}], "-", "1"}]}], "]"}]}], 
             ")"}], "&"}]}], ")"}]}], ")"}]}], ")"}]}], " ", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{"no", ".", " ", "of"}], " ", "vertex", " ", "permutations"}], 
     " ", "*)"}], ")"}], 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Times", "@@", 
        RowBox[{"foo", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ")"}], "/.", 
      RowBox[{"{", 
       RowBox[{"ex_Power", ":>", 
        RowBox[{"Factorial", "[", 
         RowBox[{"Last", "[", "ex", "]"}], "]"}]}], "}"}]}], "/.", 
     RowBox[{"_CdEdge", "->", "1"}]}], " ", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{"no", ".", " ", "of"}], " ", "edge", " ", "permutations"}], " ",
      "*)"}], "\[IndentingNewLine]", ")"}], 
   RowBox[{"(*", " ", 
    RowBox[{"compute", " ", "symmetry", " ", "factor", " ", "for", " ", 
     RowBox[{"CdGrf", "[", "]"}]}], " ", "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.978080760432048*^9, 3.978080782692753*^9}, {
   3.978080929927105*^9, 3.978080960904611*^9}, {3.9780812101569242`*^9, 
