                 RowBox[{"[", "1", "]"}], "]"}], "===", "key"}], "&"}], ",", 
              RowBox[{"Missing", "[", "\"\<NotFound\>\"", "]"}]}], "]"}]}], ";",
            "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"!", 
              RowBox[{"MissingQ", "[", "hit", "]"}]}], ",", 
             RowBox[{"Return", "[", 
              RowBox[{"hit", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "]"}], ";"}]}], "]"}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "2.", " ", "topology", " ", "iso", " ", "\:d6c4\:bcf4\:b4e4"}], 
         "*)"}], 
        RowBox[{"candidateTopoRules", "=", 
         RowBox[{"Select", "[", 
          RowBox[{"topoRules", ",", 
           RowBox[{
            RowBox[{"Quiet", "[", 
             RowBox[{
              RowBox[{"FindGraphIsomorphism", "[", 
               RowBox[{
                RowBox[{"TopoKeyToGraph", "[", "topo", "]"}], ",", 
                RowBox[{"TopoKeyToGraph", "[", 
                 RowBox[{"#", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}], "=!=", 
              RowBox[{"{", "}"}]}], "]"}], "&"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"allRules", "=", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"Normal", "/@", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "2", "]"}], "]"}], "&"}], "/@", 
              "candidateTopoRules"}], ")"}]}], ",", "1"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"3.", " ", "leaf", " ", "exact", " ", "key", " ", "hit"}], 
         "*)"}], 
        RowBox[{"hit", "=", 
         RowBox[{"SelectFirst", "[", 
          RowBox[{"allRules", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"FindGraphIsomorphism", "[", 
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ",", "key"}], "]"}], "=!=", 
             RowBox[{"{", "}"}]}], "&"}], ",", 
           RowBox[{"Missing", "[", "\"\<NotFound\>\"", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"MissingQ", "[", "hit", "]"}]}], ",", 
          RowBox[{"Return", "[", 
           RowBox[{"hit", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "4.", " ", "leaf", " ", "graph", " ", "iso", " ", "fallback"}], 
         "*)"}], 
        RowBox[{"hit", "=", 
         RowBox[{"SelectFirst", "[", 
          RowBox[{"allRules", ",", 
           RowBox[{"Function", "[", 
            RowBox[{"r", ",", 
             RowBox[{
              RowBox[{"obj", "=", 
               RowBox[{"EdgeKeyToGraph", "[", 
                RowBox[{"r", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"Quiet", "[", 
               RowBox[{
                RowBox[{"FindGraphIsomorphism", "[", 
                 RowBox[{"g", ",", "obj"}], "]"}], "=!=", 
                RowBox[{"{", "}"}]}], "]"}]}]}], "]"}], ",", 
           RowBox[{"Missing", "[", "\"\<NotFound\>\"", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"MissingQ", "[", "hit", "]"}], ",", "Null", ",", 
          RowBox[{"hit", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}]}], "]"}]}], 
    ";"}]}]}]], "Input",
