       RowBox[{"CdGrf", "[", 
        RowBox[{
         RowBox[{"VList", "@@", "vertices"}], ",", 
         RowBox[{"EList", "@@", "edges"}]}], "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
