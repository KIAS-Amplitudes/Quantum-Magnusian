Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Generates", " ", "unique", " ", "class", " ", "graphs", " ", "by", " ", 
    "ignoring", " ", "edge", " ", "directions", " ", "and", " ", "removing", " ",
     "duplicates"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"GenerateUniqueClassGraphs", "[", 
     RowBox[{"n_", "?", "IntegerQ"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "graphs", "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Generate", " ", "skeleton", " ", "diagrams", " ", "for", " ", 
        "graphs", " ", "with", " ", "n", " ", "vertices"}], "*)"}], 
      RowBox[{
       RowBox[{"graphs", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Outer", "[", 
              RowBox[{"EList", ",", 
               RowBox[{"Sequence", "@@", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"#", ",", 
                    RowBox[{"#", "//", "Reverse"}]}], "}"}], "&"}], "/@", 
                  RowBox[{"(", 
                   RowBox[{"List", "@@", 
                    RowBox[{"(", 
                    RowBox[{"#", "//", "First"}], ")"}]}], ")"}]}], ")"}]}]}],
               "]"}], "&"}], "/@", 
            RowBox[{"SkeletonDiags", "[", "n", "]"}]}], "//", "Flatten"}], 
          ")"}], "/.", " ", 
         RowBox[{"{", 
          RowBox[{"ex_EList", ":>", 
           RowBox[{"Grf", "[", 
            RowBox[{
             RowBox[{"VList", "@@", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Cases", "[", 
                 RowBox[{"ex", ",", 
                  RowBox[{"ex1_VT", ":>", 
                   RowBox[{"Vert", "[", "ex1", "]"}]}], ",", "All"}], "]"}], "//",
                 "DeleteDuplicates"}], ")"}]}], ",", "ex"}], "]"}]}], 
          "}"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Remove", " ", "duplicate", " ", "graphs", " ", "by", " ", 
         "converting", " ", "them", " ", "to", " ", "their", " ", "canonical",
          " ", "undirected", " ", "forms"}], "*)"}], 
       RowBox[{"DeleteDuplicatesBy", "[", 
        RowBox[{"graphs", ",", "ToCanonNoDirection"}], "]"}]}]}], "]"}]}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Adds", " ", "a", " ", "graph", " ", "to", " ", "the", " ", "collected", " ",
      "graphs", " ", "set"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"addGraphToSet", "[", "graph_Grf", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "}"}], ",", 
      RowBox[{
       RowBox[{"AppendTo", "[", 
        RowBox[{"CollectedGraphs", ",", "graph"}], "]"}], ";"}]}], " ", 
     RowBox[{"(*", 
      RowBox[{
      "Add", " ", "the", " ", "graph", " ", "to", " ", "the", " ", 
       "CollectedGraphs", " ", "list"}], "*)"}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Appends", " ", "a", " ", "list", " ", "of", " ", "graphs", " ", "to", " ",
      "the", " ", "TotalClassSet", " ", "based", " ", "on", " ", "vertex", " ",
      "count", " ", "n"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"addGraphToTotalSet", "[", 
     RowBox[{"graphsetlist_List", ",", "n_Integer"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Ensure", " ", "TotalClassSet", " ", "is", " ", "an", " ", 
        "association"}], "*)"}], 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"TotalClassSet", ",", "_Association"}], "]"}]}], ",", 
         RowBox[{"TotalClassSet", "=", 
          RowBox[{"<|", "|>"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Initialize", " ", "the", " ", "entry", " ", "for", " ", "vertex", " ",
          "count", " ", "n", " ", "if", " ", "it", " ", 
         RowBox[{"doesn", "'"}], "t", " ", "exist"}], "*)"}], 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"KeyExistsQ", "[", 
           RowBox[{"TotalClassSet", ",", "n"}], "]"}]}], ",", 
         RowBox[{
          RowBox[{"TotalClassSet", "[", "n", "]"}], "=", 
          RowBox[{"{", "}"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Append", " ", "the", " ", "list", " ", "of", " ", "graphs", " ", 
         "to", " ", "the", " ", "TotalClassSet", " ", "under", " ", "key", " ",
          "n"}], "*)"}], 
       RowBox[{
        RowBox[{"TotalClassSet", "[", "n", "]"}], "=", 
        RowBox[{"Append", "[", 
         RowBox[{
          RowBox[{"TotalClassSet", "[", "n", "]"}], ",", "graphsetlist"}], 
         "]"}]}], ";"}]}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.936503931108833*^9, 3.9365039328511553`*^9}, {
