    RowBox[{"Convert", " ", "list", " ", "of", " ", "edges"}], "\[RightArrow]", 
    RowBox[{"Grf", " ", 
     RowBox[{"(", 
      RowBox[{"single", "-", 
       RowBox[{"color", " ", "graph"}]}], ")"}]}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ListToGrf", "[", "edgelist_List", "]"}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"eval", ",", "vertlist"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"convert", " ", "rules", " ", "a"}], "->", 
        RowBox[{"b", " ", "into", " ", 
         RowBox[{"Edge", "[", 
          RowBox[{
           RowBox[{"VT", "[", "a", "]"}], ",", 
           RowBox[{"VT", "[", "b", "]"}]}], "]"}]}]}], "*)"}], 
      RowBox[{
       RowBox[{"eval", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"VT", "/@", 
            RowBox[{"(", 
             RowBox[{"Edge", "@@", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"#", "/.", " ", 
                 RowBox[{"{", 
                  RowBox[{"Rule", "->", "List"}], "}"}]}], "//", "Flatten"}], 
               ")"}]}], ")"}]}], ")"}], "&"}], "/@", 
         RowBox[{"(", 
          RowBox[{"EList", "@@", "edgelist"}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"extract", " ", "vertex", " ", "list"}], "*)"}], 
       RowBox[{"vertlist", "=", 
        RowBox[{"VList", "@@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Cases", "[", 
            RowBox[{"eval", ",", "_VT", ",", "All"}], "]"}], "//", 
           "DeleteDuplicates"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"construct", " ", "graph"}], ",", 
         RowBox[{"grouping", " ", "connected", " ", "edges"}]}], "*)"}], 
       RowBox[{"Times", "@@", 
        RowBox[{"ConstructGrf", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"eval", "//.", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
