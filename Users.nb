Cell[BoxData[
 RowBox[{
  RowBox[{"Grf2MMCGraphOrigin", "[", "foo_Grf", "]"}], ":=", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"FreeQ", "[", 
     RowBox[{"foo", ",", "$cl"}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Graph", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"List", "@@", 
        RowBox[{"(", 
         RowBox[{"First", "/@", 
          RowBox[{"foo", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ")"}]}], ")"}], ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"List", "@@", 
         RowBox[{"foo", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ")"}], "/.", 
       RowBox[{"{", 
        RowBox[{"Edge", "->", "DirectedEdge"}], "}"}]}]}], "]"}], " ", 
    RowBox[{"(*", " ", 
     RowBox[{"no", " ", "coloublue", " ", "vertices"}], " ", "*)"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", "$dummy", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"$dummy", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"FreeQ", "[", 
               RowBox[{"#", ",", "$cl"}], "]"}], ",", "Nothing", ",", 
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "&"}], "/@", 
           RowBox[{"foo", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "//", "First"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Graph", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"List", "@@", 
              RowBox[{"(", 
               RowBox[{"First", "/@", 
                RowBox[{"foo", "[", 
                 RowBox[{"[", "1", "]"}], "]"}]}], ")"}]}], ")"}], ",", 
            RowBox[{"VT", "[", "$cl", "]"}]}], "}"}], "//", "Flatten"}], ",", 
         
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"List", "@@", 
               RowBox[{"foo", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}], ")"}], "/.", 
             RowBox[{"{", 
              RowBox[{"Edge", "->", "DirectedEdge"}], "}"}]}], ",", 
            RowBox[{"DirectedEdge", "[", 
             RowBox[{"$dummy", ",", 
              RowBox[{"VT", "[", "$cl", "]"}]}], "]"}], ",", 
            RowBox[{"DirectedEdge", "[", 
             RowBox[{
              RowBox[{"VT", "[", "$cl", "]"}], ",", "$dummy"}], "]"}]}], 
           "}"}], "//", "Flatten"}]}], "]"}]}]}], " ", 
     RowBox[{"(*", " ", 
      RowBox[{"assume", " ", "one", " ", "coloublue", " ", "vertex"}], " ", 
      "*)"}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}], 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"convert", " ", "to", " ", "built"}], "-", 
    RowBox[{
    "in", " ", "Mathematica", " ", "graph", " ", "data", " ", "for", " ", 
