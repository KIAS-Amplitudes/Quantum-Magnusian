         RowBox[{"CdGrf", "[", 
          RowBox[{"v", ",", 
           RowBox[{"EList", "[", "edges", "]"}]}], "]"}], ",", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"reverse", " ", "direction"}], "+", 
           RowBox[{"flip", " ", "color"}]}], "*)"}], 
         RowBox[{"CdGrf", "[", 
          RowBox[{"v", ",", 
           RowBox[{"EList", "@@", 
            RowBox[{"ReplacePart", "[", 
             RowBox[{"elist", ",", 
              RowBox[{
               RowBox[{"pos", "[", 
