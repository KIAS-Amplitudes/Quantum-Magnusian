Cell[BoxData[
 RowBox[{
  RowBox[{"CanonicaliseSkGrf", "[", "foo_SkGrf", "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"foo", "/.", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Graph", "[", 
            RowBox[{"List", "@@", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"foo", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "/.", 
               RowBox[{"Edge", "->", "UndirectedEdge"}]}], ")"}]}], "]"}], "//", 
           RowBox[{
            RowBox[{"FindGraphIsomorphism", "[", 
             RowBox[{"#", ",", 
              RowBox[{"CanonicalGraph", "[", "#", "]"}]}], "]"}], "&"}]}], "//",
           "First"}], "//", "Normal"}], ")"}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Rule", "[", 
          RowBox[{"ex1_", ",", "ex2_"}], "]"}], ":>", 
         RowBox[{"Rule", "[", 
          RowBox[{"ex1", ",", 
           RowBox[{"VT", "[", "ex2", "]"}]}], "]"}]}], "}"}]}], ")"}]}], "/.", 
    RowBox[{"{", 
     RowBox[{"ex_Edge", ":>", 
      RowBox[{"Sort", "[", "ex", "]"}]}], "}"}]}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"unoriented", " ", "edges"}], " ", "*)"}], "//", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"CanonicaliseSkGrf", "[", "#", "]"}], "=", "#"}], " ", ")"}], 
    "&"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"save", " ", "canonical", " ", "skeleton", " ", "graphs"}], " ", 
    "*)"}]}]}]], "Input",
