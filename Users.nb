      RowBox[{"(*", 
       RowBox[{
       "all", " ", "vertices", " ", "in", " ", "original", " ", "graph"}], 
       "*)"}], 
      RowBox[{
       RowBox[{"allVerts", "=", 
        RowBox[{"DeleteDuplicates", "@", 
         RowBox[{"Cases", "[", 
          RowBox[{"graph", ",", "_VT", ",", "All"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"1", ")"}], " ", "remove", " ", "the", " ", "specified", " ",
          "edge"}], "*)"}], 
       RowBox[{"remainingCdEdges", "=", 
        RowBox[{"DeleteCases", "[", 
         RowBox[{
          RowBox[{"List", "@@", 
           RowBox[{"graph", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", "edgeToRemove", ",", 
          "Infinity", ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"2", ")"}], " ", "build", " ", "undirected", " ", "edges", " ",
          "for", " ", "connectivity", " ", "check"}], "*)"}], 
       RowBox[{"remainingEdgesForCC", "=", 
        RowBox[{"remainingCdEdges", "/.", " ", 
         RowBox[{
          RowBox[{"CdEdge", "[", 
           RowBox[{"a_", ",", "b_", ",", "_"}], "]"}], ":>", 
          RowBox[{"Edge", "[", 
           RowBox[{"a", ",", "b"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"compute", " ", "connected", " ", "components"}], "*)"}], 
       RowBox[{"components", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"remainingEdgesForCC", "===", 
           RowBox[{"{", "}"}]}], ",", 
          RowBox[{"{", "}"}], ",", 
          RowBox[{"GroupConnectedEdgesmodified", "[", 
           RowBox[{"EList", "@@", "remainingEdgesForCC"}], "]"}]}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"3", ")"}], " ", "build", " ", "CdGrf", " ", "subgraphs", " ",
          "for", " ", "each", " ", "component"}], "*)"}], 
       RowBox[{"subgraphs", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"Module", "[", 
            RowBox[{
             RowBox[{"{", "verts", "}"}], ",", 
             RowBox[{
              RowBox[{"verts", "=", 
               RowBox[{"DeleteDuplicates", "@", 
                RowBox[{"Flatten", "@", 
                 RowBox[{"Cases", "[", 
                  RowBox[{"#", ",", 
                   RowBox[{
                    RowBox[{"Edge", "[", 
                    RowBox[{"a_", ",", "b_"}], "]"}], ":>", 
                    RowBox[{"{", 
                    RowBox[{"a", ",", "b"}], "}"}]}], ",", "All"}], 
                  "]"}]}]}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"CdGrf", "[", 
               RowBox[{
                RowBox[{"VList", "@@", "verts"}], ",", 
                RowBox[{"EList", "@@", 
                 RowBox[{"Select", "[", 
                  RowBox[{"remainingCdEdges", ",", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"MemberQ", "[", 
                    RowBox[{"verts", ",", 
                    RowBox[{"#", "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "&&", 
                    RowBox[{"MemberQ", "[", 
                    RowBox[{"verts", ",", 
                    RowBox[{"#", "[", 
                    RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], "&"}]}], 
                  "]"}]}]}], "]"}]}]}], "]"}], ")"}], "&"}], "/@", 
         "components"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"4", ")"}], " ", "collect", " ", "vertices", " ", "already", 
         " ", "used"}], "*)"}], 
       RowBox[{"usedVerts", "=", 
        RowBox[{"DeleteDuplicates", "@", 
         RowBox[{"Flatten", "[", 
          RowBox[{"Cases", "[", 
           RowBox[{"subgraphs", ",", "_VT", ",", "All"}], "]"}], "]"}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"5", ")"}], " ", "find", " ", "isolated", " ", "vertices"}], 
        "*)"}], 
       RowBox[{"isolatedVerts", "=", 
        RowBox[{"Complement", "[", 
         RowBox[{"allVerts", ",", "usedVerts"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"6", ")"}], " ", "add", " ", "isolated", " ", "vertices", " ",
          "as", " ", "singleton", " ", "graphs"}], "*)"}], 
       RowBox[{"Join", "[", 
        RowBox[{"subgraphs", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"CdGrf", "[", 
             RowBox[{
              RowBox[{"VList", "[", "#", "]"}], ",", 
              RowBox[{"EList", "[", "]"}]}], "]"}], "&"}], ")"}], "/@", 
          "isolatedVerts"}]}], "]"}]}]}], "]"}]}]}]}]], "Input",
