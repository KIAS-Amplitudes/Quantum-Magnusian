Cell[CellGroupData[{

Cell["Graph generation and flipping", "Subsection",
 CellChangeTimes->{
  3.936503841224834*^9, 3.936505762367288*^9, 3.936506146513043*^9, {
   3.938144902531708*^9, 
   3.938144906404974*^9}},ExpressionUUID->"74e9dc77-c9ee-422b-b0ef-\
cdd555979835"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Flips", " ", "the", " ", "direction", " ", "of", " ", "a", " ", 
    "specified", " ", "edge", " ", "in", " ", "a", " ", "graph"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"FlipEdge", "[", 
     RowBox[{"graph_", ",", "edge_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "newGraph", "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Create", " ", "a", " ", "copy", " ", "of", " ", "the", " ", 
        "original", " ", "graph"}], "*)"}], 
      RowBox[{
       RowBox[{"newGraph", "=", "graph"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Replace", " ", "the", " ", "specified", " ", "edge", " ", "with", " ",
          "its", " ", "reversed", " ", "direction"}], "*)"}], 
       RowBox[{"newGraph", "=", 
        RowBox[{"newGraph", "/.", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Edge", "[", 
            RowBox[{
             RowBox[{"edge", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", 
             RowBox[{"edge", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ":>", 
           RowBox[{"Edge", "[", 
            RowBox[{
             RowBox[{"edge", "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", 
             RowBox[{"edge", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], "}"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Return", " ", "the", " ", "modified", " ", "graph"}], "*)"}],
        "newGraph"}]}], "]"}]}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Generates", " ", "all", " ", "possible", " ", "graphs", " ", "by", " ", 
     "flipping", " ", "each", " ", "edge", " ", "in", " ", "the", " ", 
     "given", " ", "graph", " ", "set"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"GenerateFullyFlippedGraphsSet", "[", "graphs_List", "]"}], ":=", 
    
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"edges", ",", "flippedGraphs", ",", "currentGraph"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Iterate", " ", "over", " ", "each", " ", "graph", " ", "in", " ", 
        "the", " ", "input", " ", "list"}], "*)"}], 
      RowBox[{"Flatten", "[", 
       RowBox[{"Table", "[", 
        RowBox[{"(*", 
         RowBox[{
         "Extract", " ", "the", " ", "list", " ", "of", " ", "edges", " ", 
          "from", " ", "the", " ", "current", " ", "graph"}], "*)"}], 
        RowBox[{
         RowBox[{
          RowBox[{"edges", "=", 
           RowBox[{"List", "@@", 
            RowBox[{"(", 
             RowBox[{"graph", "[", 
              RowBox[{"[", "2", "]"}], "]"}], ")"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Initialize", " ", "an", " ", "empty", " ", "list", " ", "to", " ",
             "store", " ", "flipped", " ", "versions", " ", "of", " ", "the", 
            " ", "current", " ", "graph"}], "*)"}], 
          RowBox[{"flippedGraphs", "=", 
           RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Start", " ", "with", " ", "the", " ", "original", " ", "graph"}], 
           "*)"}], 
          RowBox[{"currentGraph", "=", "graph"}], ";", "\[IndentingNewLine]", 
          
          RowBox[{"(*", 
           RowBox[{
           "Flip", " ", "each", " ", "edge", " ", "one", " ", "by", " ", 
            "one", " ", "and", " ", "store", " ", "the", " ", "resulting", " ",
             "graphs"}], "*)"}], 
          RowBox[{"Do", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"currentGraph", "=", 
              RowBox[{"FlipEdge", "[", 
               RowBox[{"currentGraph", ",", 
                RowBox[{"edges", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"AppendTo", "[", 
              RowBox[{"flippedGraphs", ",", "currentGraph"}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", 
              RowBox[{"Length", "[", "edges", "]"}]}], "}"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Collect", " ", "all", " ", "flipped", " ", "graphs", " ", "for", " ",
             "the", " ", "current", " ", "graph"}], "*)"}], "flippedGraphs"}],
          ",", 
         RowBox[{"{", 
          RowBox[{"graph", ",", "graphs"}], "}"}]}], "]"}], "]"}]}], "]"}]}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Alternates", " ", "the", " ", "direction", " ", "of", " ", "edges", " ",
       "in", " ", "a", " ", "graph", " ", "using", " ", "breadth"}], "-", 
     RowBox[{"first", " ", "traversal"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"AlternateEdgeDirections", "[", "graph_Grf", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"edges", ",", 
        RowBox[{"visitedEdges", "=", 
         RowBox[{"{", "}"}]}], ",", "currentVertex", ",", "nextVertex", ",", 
        "edgeDirection", ",", 
        RowBox[{"orientedEdges", "=", 
         RowBox[{"{", "}"}]}], ",", "queue"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Extract", " ", "the", " ", "list", " ", "of", " ", "edges", " ", 
        "from", " ", "the", " ", "graph"}], "*)"}], 
      RowBox[{
       RowBox[{"edges", "=", 
        RowBox[{"List", "@@", 
         RowBox[{"graph", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Select", " ", "the", " ", "starting", " ", 
         RowBox[{"vertex", ":", 
          RowBox[{
          "the", " ", "first", " ", "vertex", " ", "in", " ", "the", " ", 
           "graph"}]}]}], "*)"}], 
       RowBox[{"currentVertex", "=", 
        RowBox[{
         RowBox[{"First", "[", 
          RowBox[{"graph", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Initialize", " ", "the", " ", "queue", " ", "with", " ", "the", " ", 
         "starting", " ", "vertex", " ", "and", " ", "an", " ", "initial", " ",
          "direction", " ", "flag", " ", "of", " ", "1"}], "*)"}], 
       RowBox[{"queue", "=", 
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"currentVertex", ",", "1"}], "}"}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Perform", " ", "breadth"}], "-", 
         RowBox[{
         "first", " ", "traversal", " ", "to", " ", "alternate", " ", "edge", 
          " ", "directions"}]}], "*)"}], 
       RowBox[{"While", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "queue", "]"}], ">", "0"}], ",", 
         RowBox[{"(*", 
          RowBox[{"Dequeue", " ", "the", " ", "first", " ", 
           RowBox[{"element", ":", 
            RowBox[{
            "current", " ", "vertex", " ", "and", " ", "its", " ", 
             "direction", " ", "flag"}]}]}], "*)"}], 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"currentVertex", ",", "edgeDirection"}], "}"}], "=", 
           RowBox[{"First", "[", "queue", "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"queue", "=", 
           RowBox[{"Rest", "[", "queue", "]"}]}], ";", "\[IndentingNewLine]", 
          
          RowBox[{"(*", 
           RowBox[{
           "Find", " ", "all", " ", "edges", " ", "connected", " ", "to", " ",
             "the", " ", "current", " ", "vertex"}], "*)"}], 
          RowBox[{"Do", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"(*", 
              RowBox[{
              "Determine", " ", "the", " ", "adjacent", " ", "vertex", " ", 
               "based", " ", "on", " ", "the", " ", "edge", " ", 
               "direction"}], "*)"}], 
             RowBox[{
              RowBox[{"nextVertex", "=", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"edge", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "===", "currentVertex"}], ",", 
                 RowBox[{"edge", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], ",", 
                 RowBox[{"edge", "[", 
                  RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
               "Skip", " ", "the", " ", "edge", " ", "if", " ", "it", " ", 
                "has", " ", "already", " ", "been", " ", "visited"}], "*)"}], 
              
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"MemberQ", "[", 
                 RowBox[{"visitedEdges", ",", "edge"}], "]"}], ",", 
                RowBox[{"Continue", "[", "]"}]}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
               "Set", " ", "the", " ", "direction", " ", "of", " ", "the", " ",
                 "edge", " ", "based", " ", "on", " ", "the", " ", "current", 
                " ", "direction", " ", "flag"}], "*)"}], 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"edgeDirection", "==", "1"}], ",", 
                RowBox[{"AppendTo", "[", 
                 RowBox[{"orientedEdges", ",", 
                  RowBox[{"Edge", "[", 
                   RowBox[{"currentVertex", ",", "nextVertex"}], "]"}]}], 
                 "]"}], ",", 
                RowBox[{"AppendTo", "[", 
                 RowBox[{"orientedEdges", ",", 
                  RowBox[{"Edge", "[", 
                   RowBox[{"nextVertex", ",", "currentVertex"}], "]"}]}], 
                 "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
               "Enqueue", " ", "the", " ", "adjacent", " ", "vertex", " ", 
                "with", " ", "the", " ", "opposite", " ", "direction", " ", 
                "flag"}], "*)"}], 
              RowBox[{"AppendTo", "[", 
               RowBox[{"queue", ",", 
                RowBox[{"{", 
                 RowBox[{"nextVertex", ",", 
                  RowBox[{"-", "edgeDirection"}]}], "}"}]}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
               "Mark", " ", "the", " ", "edge", " ", "as", " ", "visited"}], 
               "*)"}], 
              RowBox[{"AppendTo", "[", 
               RowBox[{"visitedEdges", ",", "edge"}], "]"}]}], ")"}], ",", 
            RowBox[{"{", 
             RowBox[{"edge", ",", 
              RowBox[{"Select", "[", 
               RowBox[{"edges", ",", 
                RowBox[{
                 RowBox[{"MemberQ", "[", 
                  RowBox[{"#", ",", "currentVertex"}], "]"}], "&"}]}], 
               "]"}]}], "}"}]}], "]"}], ";"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Return", " ", "the", " ", "new", " ", "graph", " ", "with", " ", 
         "alternately", " ", "directed", " ", "edges"}], "*)"}], 
       RowBox[{"Grf", "[", 
        RowBox[{
         RowBox[{"graph", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"EList", "@@", "orientedEdges"}]}], "]"}]}]}], 
     "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.936505275762032*^9, 3.93650527576497*^9}, 
