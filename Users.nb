   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"===", 
      RowBox[{"==", 
       RowBox[{
        RowBox[{"Root", "/", "neighbor"}], " ", "utilities"}]}], "===", "===",
       "===", "===", "===", "===", "==="}], "="}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Retrieves", " ", "the", " ", "neighbors", " ", "of", " ", "a", " ", 
     "given", " ", "root", " ", "vertex", " ", "in", " ", "graph", " ", "A"}],
     "*)"}], "\n", 
   RowBox[{
    RowBox[{"GetNeighbors", "[", 
     RowBox[{"A_Grf", ",", "rootVertex_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "neighbors", "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Extract", " ", "vertices", " ", "connected", " ", "to", " ", 
        "rootVertex", " ", "via", " ", "outgoing", " ", "edges"}], "*)"}], 
      RowBox[{
       RowBox[{"neighbors", "=", 
        RowBox[{"Cases", "[", 
         RowBox[{
          RowBox[{"List", "@@", 
           RowBox[{"A", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"Edge", "[", 
            RowBox[{"x_", ",", "rootVertex"}], "]"}], ":>", "x"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", "neighbors"}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Finds", " ", "the", " ", "root", " ", "vertex", " ", "of", " ", "a", " ",
      "graph", " ", "based", " ", "on", " ", "degree", " ", "criteria"}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"FindRoots", "[", "graph_Grf", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "inDegreeList", ",", "outDegreeList", ",", "vertices", ",", 
        "candidates", ",", "root"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Extract", " ", "all", " ", "vertex", " ", "identifiers", " ", "from", 
        " ", "the", " ", "graph"}], "*)"}], 
      RowBox[{
       RowBox[{"vertices", "=", 
        RowBox[{"First", "/@", 
         RowBox[{"List", "@@", 
          RowBox[{"graph", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Compute", " ", "out"}], "-", 
         RowBox[{"degree", " ", "for", " ", "each", " ", "vertex"}]}], "*)"}], 
       RowBox[{"outDegreeList", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"v", ",", 
            RowBox[{"Count", "[", 
             RowBox[{
              RowBox[{"graph", "[", 
               RowBox[{"[", "2", "]"}], "]"}], ",", 
              RowBox[{"Edge", "[", 
               RowBox[{"v", ",", "_"}], "]"}]}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"v", ",", "vertices"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Select", " ", "vertices", " ", "with", " ", "out"}], "-", 
         RowBox[{"degree", " ", "0", " ", "as", " ", "candidates"}]}], "*)"}], 
       RowBox[{"candidates", "=", 
        RowBox[{
         RowBox[{"Select", "[", 
          RowBox[{"outDegreeList", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"#", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "==", "0"}], "&"}]}], "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
