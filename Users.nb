             "]"}]}]}], "]"}]}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Remove", " ", "a", " ", "single", " ", "edge", " ", "and", " ", "split", 
     " ", "the", " ", "graph", " ", "into", " ", "connected", " ", 
     "components"}], "*)"}], 
   RowBox[{
    RowBox[{"SplitGraphByEdge", "[", 
     RowBox[{"graph_CdGrf", ",", "edgeToRemove_CdEdge"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "allVerts", ",", "remainingCdEdges", ",", "remainingEdgesForCC", ",", 
