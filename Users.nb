    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"elist", "=", 
         RowBox[{"{", "edges", "}"}]}], ",", "pos", ",", "flipColor"}], "}"}],
       ",", 
      RowBox[{"(*", 
       RowBox[{"color", " ", "switch", " ", "function"}], "*)"}], 
      RowBox[{
       RowBox[{
        RowBox[{"flipColor", "[", "c_", "]"}], ":=", 
        RowBox[{"Switch", "[", 
         RowBox[{
         "c", ",", "$c2", ",", "$c1", ",", "$c1", ",", "$c2", ",", "_", ",", 
          "c"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"pos", "=", 
        RowBox[{"FirstPosition", "[", 
         RowBox[{"elist", ",", "edge"}], "]"}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"pos", "===", 
          RowBox[{"Missing", "[", "\"\<NotFound\>\"", "]"}]}], ",", 
         RowBox[{"CdGrf", "[", 
          RowBox[{"v", ",", 
           RowBox[{"EList", "[", "edges", "]"}]}], "]"}], ",", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"keep", " ", "direction"}], ",", 
           RowBox[{"flip", " ", "color"}]}], "*)"}], 
         RowBox[{"CdGrf", "[", 
          RowBox[{"v", ",", 
           RowBox[{"EList", "@@", 
            RowBox[{"ReplacePart", "[", 
             RowBox[{"elist", ",", 
              RowBox[{
               RowBox[{"pos", "[", 
