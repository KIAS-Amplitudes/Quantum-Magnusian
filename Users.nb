         RowBox[{
          RowBox[{"gGrf", "=", 
           RowBox[{"ToCanon", "@", 
            RowBox[{"CdToGrfForTable", "[", "grf", "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"ensure", " ", 
            RowBox[{"omega", "/", "e"}], " ", "precomputed"}], "*)"}], 
          RowBox[{"OnlyCalculatingOmegaAndE", "[", 
           RowBox[{"VertexCountCd", "[", "grf", "]"}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"sign", " ", "from", " ", "blue", " ", "edges"}], "*)"}], 
          RowBox[{"val", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", "1"}], ")"}], "^", 
             RowBox[{"CountC2", "[", "grf", "]"}]}], "*", 
            RowBox[{"e", "[", "gGrf", "]"}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"eCdTable", "[", "key", "]"}], "=", "val"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Return", "[", 
           RowBox[{"factorcut", " ", "val"}], "]"}], ";"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"5", ")"}], " ", "general", " ", "recursive", " ", "step", " ", 
         RowBox[{"(", 
          RowBox[{"vertex", " ", "removal", " ", "identity"}], ")"}]}], 
        "*)"}], 
       RowBox[{"vin", "=", 
        RowBox[{"AllInVertices", "[", "grf", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"m", "=", 
        RowBox[{"VertexCountCd", "[", "grf", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "average", " ", "over", " ", "all", " ", "valid", " ", "incoming", " ",
          "vertices"}], "*)"}], 
       RowBox[{"val", "=", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"eContribution", "[", 
             RowBox[{"grf", ",", "#"}], "]"}], "&"}], "/@", "vin"}], "]"}], "/",
          "m"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"eCdTable", "[", "key", "]"}], "=", "val"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"factorcut", " ", "val"}]}]}], "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"blueuce", " ", "CdGrf"}], "\[RightArrow]", 
     RowBox[{"Graph", " ", "form", " ", "first"}]}], "*)"}], 
   RowBox[{
    RowBox[{
     RowBox[{"eCfFunc", "[", "g_CdGrf", "]"}], ":=", 
     RowBox[{"eCfFunc", "[", 
      RowBox[{
       RowBox[{"g", "//", "C2toC1"}], "//", "C1LoopToGraph2"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eContribution", "[", 
     RowBox[{"g_CdGrf", ",", "v_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"g2", ",", "comps", ",", "loops"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{"remove", " ", "vertex", " ", "v"}], "*)"}], 
      RowBox[{
       RowBox[{"g2", "=", 
        RowBox[{"RemoveVertex", "[", 
         RowBox[{"g", ",", "v"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"split", " ", "into", " ", "connected", " ", "components"}], 
        "*)"}], 
       RowBox[{"comps", "=", 
        RowBox[{"SplitDisconnected", "[", "g2", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "loop", " ", "number", " ", "of", " ", "original", " ", "graph"}], 
        "*)"}], 
       RowBox[{"loops", "=", 
        RowBox[{
         RowBox[{"Length", "[", 
          RowBox[{"EdgesOf", "[", "g", "]"}], "]"}], "-", 
         RowBox[{"VertexCountCd", "[", "g", "]"}], "+", "1"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"\:0127", "^", "loops"}], "\[Times]", "product", " ", "of", " ",
          "subgraph", " ", "contributions"}], "*)"}], 
       RowBox[{"Times", "@@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"eCfFunc", "[", "#", "]"}], "&"}], "/@", "comps"}], 
         ")"}]}]}]}], "]"}]}]}]}]], "Input",
