    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"elist", "=", 
         RowBox[{"{", "edges", "}"}]}], ",", "pos"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{"find", " ", "position", " ", "of", " ", "the", " ", "edge"}], 
       "*)"}], 
      RowBox[{
       RowBox[{"pos", "=", 
        RowBox[{"FirstPosition", "[", 
         RowBox[{"elist", ",", "edge"}], "]"}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"if", " ", "not", " ", "found"}], ",", 
         RowBox[{"return", " ", "original", " ", "graph"}]}], "*)"}], 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"pos", "===", 
          RowBox[{"Missing", "[", "\"\<NotFound\>\"", "]"}]}], ",", 
         RowBox[{"CdGrf", "[", 
          RowBox[{"v", ",", 
           RowBox[{"EList", "[", "edges", "]"}]}], "]"}], ",", 
         RowBox[{"(*", 
          RowBox[{"replace", " ", "with", " ", "reversed", " ", "direction"}],
           "*)"}], 
         RowBox[{"CdGrf", "[", 
          RowBox[{"v", ",", 
           RowBox[{"EList", "@@", 
            RowBox[{"ReplacePart", "[", 
             RowBox[{"elist", ",", 
              RowBox[{
               RowBox[{"pos", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "->", 
               RowBox[{"CdEdge", "[", 
                RowBox[{
                 RowBox[{"edge", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], ",", 
                 RowBox[{"edge", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], ",", 
                 RowBox[{"edge", "[", 
                  RowBox[{"[", "3", "]"}], "]"}]}], "]"}]}]}], "]"}]}]}], 
          "]"}]}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Flip", " ", "only", " ", "color", " ", "of", " ", "a", " ", "given", " ",
      "edge"}], "*)"}], 
   RowBox[{
    RowBox[{"ReverseColobluege", "[", 
