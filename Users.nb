Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"CdGrf", " ", 
    RowBox[{"version", ":", 
     RowBox[{"Remove", " ", "a", " ", "directed", " ", "edge", " ", 
      RowBox[{"(", 
       RowBox[{"va", "->", "vb"}], ")"}], " ", "and", " ", "merge", " ", "vb",
       " ", "into", " ", "va"}]}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"MergeGraph", "[", 
     RowBox[{"grf_CdGrf", ",", "edgeToRemove_CdEdge"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "edges", ",", "vertices", ",", "vToRemove", ",", "vKeep", ",", 
        "blueirect"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"1", ")"}], " ", "extract", " ", "edge", " ", "list", " ", 
        RowBox[{"(", 
         RowBox[{"no", " ", "immediate", " ", "deletion", " ", "here"}], 
         ")"}]}], "*)"}], 
      RowBox[{
       RowBox[{"edges", "=", 
        RowBox[{"List", "@@", 
         RowBox[{"grf", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"2", ")"}], " ", "decide", " ", "merge", " ", 
           RowBox[{"direction", ":", "keep"}]}], "=", "source"}], ",", 
         RowBox[{"remove", "=", "target"}]}], "*)"}], 
       RowBox[{"vKeep", "=", 
        RowBox[{"edgeToRemove", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"vToRemove", "=", 
        RowBox[{"edgeToRemove", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
          RowBox[{"3", ")"}], " ", "blueirect", " ", "all", " ", 
          "occurrences", " ", "of", " ", "vToRemove"}], "\[RightArrow]", 
         "vKeep"}], "*)"}], 
       RowBox[{
        RowBox[{"blueirect", "[", "x_", "]"}], ":=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"x", "===", "vToRemove"}], ",", "vKeep", ",", "x"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"edges", "=", 
        RowBox[{"edges", "/.", " ", 
         RowBox[{
          RowBox[{"CdEdge", "[", 
           RowBox[{"a_", ",", "b_", ",", "c_"}], "]"}], ":>", 
          RowBox[{"CdEdge", "[", 
           RowBox[{
            RowBox[{"blueirect", "[", "a", "]"}], ",", 
            RowBox[{"blueirect", "[", "b", "]"}], ",", "c"}], "]"}]}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
          RowBox[{"4", ")"}], " ", "remove", " ", "the", " ", "self"}], "-", 
         RowBox[{"loop", " ", "created", " ", "at", " ", "vKeep", " ", 
          RowBox[{"(", 
           RowBox[{"same", " ", "color", " ", "only"}], ")"}]}]}], "*)"}], 
       RowBox[{"edges", "=", 
        RowBox[{"DeleteCases", "[", 
         RowBox[{"edges", ",", 
          RowBox[{"CdEdge", "[", 
           RowBox[{"vKeep", ",", "vKeep", ",", 
            RowBox[{"edgeToRemove", "[", 
             RowBox[{"[", "3", "]"}], "]"}]}], "]"}], ",", "Infinity", ",", 
          "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"5", ")"}], " ", "remove", " ", "vToRemove", " ", "from", " ",
          "vertex", " ", "list"}], "*)"}], 
       RowBox[{"vertices", "=", 
        RowBox[{"DeleteCases", "[", 
         RowBox[{
          RowBox[{"grf", "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", "vToRemove"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"6", ")"}], " ", "return", " ", "merged", " ", "graph"}], 
