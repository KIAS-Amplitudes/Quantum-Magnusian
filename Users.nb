Cell[CellGroupData[{

Cell["Graph modification functions", "Subsection",
 CellChangeTimes->{
  3.936503753077671*^9, {3.938144881620854*^9, 
   3.938144884840192*^9}},ExpressionUUID->"bc57d5c8-78d4-41fd-8d32-\
e9731352a724"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Converts", " ", "a", " ", "Grf", " ", "object", " ", "to", " ", "an", " ",
     "undirected", " ", "canonical", " ", "graph"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ToCanonNoDirection", "[", "graph_Grf", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "undirGraph", "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Convert", " ", "the", " ", "vertex", " ", "list", " ", "by", " ", 
        "removing", " ", "the", " ", "Vert", " ", "wrapper"}], "*)"}], 
      RowBox[{
       RowBox[{"undirGraph", "=", 
        RowBox[{"Graph", "[", 
         RowBox[{
          RowBox[{"List", "@@", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"graph", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "/.", " ", 
             RowBox[{"Vert", "->", "Identity"}]}], ")"}]}], ",", 
          RowBox[{"(*", 
           RowBox[{
           "Convert", " ", "directed", " ", "edges", " ", "to", " ", 
            "undirected", " ", "edges"}], "*)"}], 
          RowBox[{"List", "@@", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"graph", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "/.", " ", 
             RowBox[{"Edge", "->", "UndirectedEdge"}]}], ")"}]}]}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Return", " ", "the", " ", "canonical", " ", "form", " ", "of", " ", 
         "the", " ", "undirected", " ", "graph"}], "*)"}], 
       RowBox[{"CanonicalGraph", "[", "undirGraph", "]"}]}]}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Reverses", " ", "all", " ", "edges", " ", "in", " ", "a", " ", "Grf", " ",
      "graph"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ReverseAllEdges", "[", "graph_Grf", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"vertices", ",", "edges", ",", "flippedEdges"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Extract", " ", "vertices", " ", "and", " ", "edges", " ", "from", " ",
         "the", " ", "Grf", " ", "object"}], "*)"}], 
      RowBox[{
       RowBox[{"vertices", "=", 
        RowBox[{"graph", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"edges", "=", 
        RowBox[{"graph", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Reverse", " ", "each", " ", "edge", " ", "by", " ", "swapping", " ", 
         "its", " ", "vertices"}], "*)"}], 
       RowBox[{"flippedEdges", "=", 
        RowBox[{"edges", "/.", " ", 
         RowBox[{
          RowBox[{"Edge", "[", 
           RowBox[{"v1_", ",", "v2_"}], "]"}], ":>", 
          RowBox[{"Edge", "[", 
           RowBox[{"v2", ",", "v1"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Return", " ", "a", " ", "new", " ", "Grf", " ", "object", " ", 
         "with", " ", "the", " ", "reversed", " ", "edges"}], "*)"}], 
       RowBox[{"Grf", "[", 
        RowBox[{"vertices", ",", "flippedEdges"}], "]"}]}]}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Reverses", " ", "all", " ", "edges", " ", "in", " ", "a", " ", 
     "standard", " ", "Graph", " ", "object"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ReverseAllEdges", "[", "graph_Graph", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"edges", ",", "reversedEdges"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Extract", " ", "the", " ", "list", " ", "of", " ", "edges", " ", 
        "from", " ", "the", " ", "Graph", " ", "object"}], "*)"}], 
      RowBox[{
       RowBox[{"edges", "=", 
        RowBox[{"EdgeList", "[", "graph", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Reverse", " ", "each", " ", "directed", " ", "edge"}], 
        "*)"}], 
       RowBox[{"reversedEdges", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"DirectedEdge", "[", 
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "2", "]"}], "]"}], ",", 
            RowBox[{"#", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "&"}], "/@", 
         "edges"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Return", " ", "a", " ", "new", " ", "Graph", " ", "with", " ", 
         "reversed", " ", "edges", " ", "and", " ", "the", " ", "same", " ", 
         "vertices"}], "*)"}], 
       RowBox[{"Graph", "[", 
        RowBox[{
         RowBox[{"VertexList", "[", "graph", "]"}], ",", "reversedEdges"}], 
        "]"}]}]}], "]"}]}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Merges", " ", "two", " ", "vertices", " ", "in", " ", "a", " ", "graph", 
     " ", "by", " ", "removing", " ", "a", " ", "specified", " ", "edge"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"MergeGraph", "[", 
     RowBox[{"grf_Grf", ",", "edgeToRemove_Edge"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"edges", ",", "vertices", ",", "vToRemove", ",", "vKeep"}], 
       "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Remove", " ", "the", " ", "specified", " ", "edge", " ", "from", " ", 
        "the", " ", "edge", " ", "list"}], "*)"}], 
      RowBox[{
       RowBox[{"edges", "=", 
        RowBox[{"DeleteCases", "[", 
         RowBox[{
          RowBox[{"List", "@@", 
           RowBox[{"grf", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", "edgeToRemove"}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Identify", " ", "the", " ", "vertices", " ", "to", " ", "remove", " ",
          "and", " ", "keep"}], "*)"}], 
       RowBox[{"vToRemove", "=", 
        RowBox[{"edgeToRemove", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"vKeep", "=", 
        RowBox[{"edgeToRemove", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "blueirect", " ", "edges", " ", "connected", " ", "to", " ", "the", " ",
          "removed", " ", "vertex", " ", "to", " ", "the", " ", "kept", " ", 
         "vertex"}], "*)"}], 
       RowBox[{"edges", "=", 
        RowBox[{"edges", "/.", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Edge", "[", 
              RowBox[{"a_", ",", "b_"}], "]"}], "/;", 
             RowBox[{"b", "===", "vToRemove"}]}], ":>", 
            RowBox[{"Edge", "[", 
             RowBox[{"a", ",", "vKeep"}], "]"}]}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"Edge", "[", 
              RowBox[{"a_", ",", "b_"}], "]"}], "/;", 
             RowBox[{"a", "===", "vToRemove"}]}], ":>", 
            RowBox[{"Edge", "[", 
             RowBox[{"vKeep", ",", "b"}], "]"}]}]}], "}"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Remove", " ", "duplicate", " ", "edges", " ", "that", " ", "may", " ",
          "have", " ", "been", " ", "created", " ", "by", " ", "merging"}], 
        "*)"}], 
       RowBox[{"edges", "=", 
        RowBox[{"DeleteDuplicates", "[", "edges", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Remove", " ", "any", " ", "self"}], "-", 
         RowBox[{
         "loops", " ", "that", " ", "may", " ", "have", " ", "been", " ", 
          "created"}]}], "*)"}], 
       RowBox[{"edges", "=", 
        RowBox[{"DeleteCases", "[", 
         RowBox[{"edges", ",", 
          RowBox[{"Edge", "[", 
           RowBox[{"vKeep", ",", "vKeep"}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Remove", " ", "the", " ", "vertex", " ", "that", " ", "has", " ", 
         "been", " ", "merged"}], "*)"}], 
       RowBox[{"vertices", "=", 
        RowBox[{"DeleteCases", "[", 
         RowBox[{
          RowBox[{"grf", "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          RowBox[{"Vert", "[", "vToRemove", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Return", " ", "the", " ", "new", " ", "Grf", " ", "object", " ", 
         "with", " ", "merged", " ", "vertices", " ", "and", " ", "updated", " ",
          "edges"}], "*)"}], 
       RowBox[{"Grf", "[", 
        RowBox[{
         RowBox[{"VList", "@@", "vertices"}], ",", 
         RowBox[{"EList", "@@", "edges"}]}], "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Splits", " ", "a", " ", "graph", " ", "into", " ", "subgraphs", " ", 
     "by", " ", "removing", " ", "a", " ", "specified", " ", "edge"}], "*)"}],
    "\n", 
   RowBox[{
    RowBox[{"SplitGraphByEdge", "[", 
     RowBox[{"graph_Grf", ",", "edgeToRemove_Edge"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "edges", ",", "remainingEdges", ",", "connectedComponents", ",", 
        "subgraphs"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Remove", " ", "the", " ", "specified", " ", "edge", " ", "from", " ", 
        "the", " ", "edge", " ", "list"}], "*)"}], 
      RowBox[{
       RowBox[{"remainingEdges", "=", 
        RowBox[{"DeleteCases", "[", 
         RowBox[{
          RowBox[{"List", "@@", 
           RowBox[{"graph", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", "edgeToRemove"}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Group", " ", "the", " ", "remaining", " ", "edges", " ", "into", " ",
          "connected", " ", "components"}], "*)"}], 
       RowBox[{"connectedComponents", "=", 
        RowBox[{"GroupConnectedEdgesmodified", "[", 
         RowBox[{"EList", "@@", "remainingEdges"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Create", " ", "subgraphs", " ", "for", " ", "each", " ", "connected",
          " ", "component"}], "*)"}], 
       RowBox[{"subgraphs", "=", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"Grf", "[", 
            RowBox[{
             RowBox[{"VList", "@@", 
              RowBox[{"DeleteDuplicates", "[", 
               RowBox[{"Cases", "[", 
                RowBox[{"#", ",", 
                 RowBox[{
                  RowBox[{"VT", "[", "x_", "]"}], ":>", 
                  RowBox[{"Vert", "[", 
                   RowBox[{"VT", "[", "x", "]"}], "]"}]}], ",", "All"}], 
                "]"}], "]"}]}], ",", "#"}], "]"}], "&"}], "/@", 
          "connectedComponents"}], ")"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Return", " ", "the", " ", "list", " ", "of", " ", "subgraphs"}], 
        "*)"}], "subgraphs"}]}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.93650526775334*^9, 3.936505267756364*^9}, {
   3.936505622730693*^9, 3.936505647239696*^9}, 3.93814580248272*^9, 
   3.9859181754656467`*^9},
 CellLabel->
  "In[519]:=",ExpressionUUID->"a3fd9c52-ea9b-45f8-9c14-28f924ed60d7"]
}, Closed]],

Cell[CellGroupData[{

Cell["Graph grouping and sorting", "Subsection",
 CellChangeTimes->{
  3.936505842817194*^9, {3.938144919827512*^9, 
   3.938144922655464*^9}},ExpressionUUID->"e4c81dcf-d5be-43f2-a81c-\
f1c15e565deb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Groups", " ", "graphs", " ", "by", " ", "canonical", " ", "undirected", " ",
     "form", " ", "and", " ", "sorts", " ", "them"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"GroupAndSortGraphs", "[", "graphs_List", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"groupedGraphs", ",", "sortedGroups"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Group", " ", "graphs", " ", "based", " ", "on", " ", "their", " ", 
        "canonical", " ", "undirected", " ", "forms"}], "*)"}], 
      RowBox[{
       RowBox[{"groupedGraphs", "=", 
        RowBox[{"GatherBy", "[", 
         RowBox[{"graphs", ",", "ToCanonNoDirection"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "Sort", " ", "the", " ", "groups", " ", "based", " ", "on", " ", 
          "the", " ", "maximum", " ", "eTable", " ", "value", " ", "in", " ", 
          "each", " ", "group"}], ",", "descending"}], "*)"}], 
       RowBox[{"sortedGroups", "=", 
        RowBox[{"SortBy", "[", 
         RowBox[{"groupedGraphs", ",", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"Max", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"KeyExistsQ", "[", 
                  RowBox[{"eTable", ",", 
                   RowBox[{"ToCanon", "[", "#", "]"}]}], "]"}], ",", 
                 RowBox[{"eTable", "[", 
                  RowBox[{"ToCanon", "[", "#", "]"}], "]"}], ",", "0"}], 
                "]"}], "&"}], "/@", "#"}], "]"}]}], "&"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Within", " ", "each", " ", "group"}], ",", 
         RowBox[{
         "sort", " ", "the", " ", "graphs", " ", "by", " ", "maximum", " ", 
          "wTable", " ", "value"}], ",", "descending"}], "*)"}], 
       RowBox[{"sortedGroups", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"SortBy", "[", 
           RowBox[{"#", ",", 
            RowBox[{
             RowBox[{"-", 
              RowBox[{"Max", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{"KeyExistsQ", "[", 
                    RowBox[{"wTable", ",", 
                    RowBox[{"ToCanon", "[", "#", "]"}]}], "]"}], ",", 
                   RowBox[{"wTable", "[", 
                    RowBox[{"ToCanon", "[", "#", "]"}], "]"}], ",", "0"}], 
                  "]"}], "&"}], "/@", "#"}], "]"}]}], "&"}]}], "]"}], "&"}], "/@",
          "sortedGroups"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Return", " ", "the", " ", "sorted", " ", "groups", " ", "of", " ", 
         "graphs"}], "*)"}], "sortedGroups"}]}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Sorts", " ", "a", " ", "single", " ", "group", " ", "of", " ", "graphs", 
     " ", "by", " ", "eTable", " ", "ascending", " ", "and", " ", "wTable", " ",
      "descending"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SortSingleGroupUD", "[", "group_List", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "sortedGroup", "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
        "Sort", " ", "the", " ", "group", " ", "first", " ", "by", " ", 
         "eTable", " ", "in", " ", "ascending", " ", "order"}], ",", 
        RowBox[{
        "then", " ", "by", " ", "wTable", " ", "in", " ", "descending", " ", 
         "order"}]}], "*)"}], 
      RowBox[{
       RowBox[{"sortedGroup", "=", 
        RowBox[{"SortBy", "[", 
         RowBox[{"group", ",", 
          RowBox[{"{", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{
              RowBox[{"Sort", " ", "by", " ", "eTable", " ", "value"}], ";", 
              RowBox[{"if", " ", "not", " ", "present"}]}], ",", 
             RowBox[{
             "assign", " ", "Infinity", " ", "to", " ", "place", " ", "at", 
              " ", "the", " ", "end"}]}], "*)"}], 
           RowBox[{
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"KeyExistsQ", "[", 
                RowBox[{"eTable", ",", 
                 RowBox[{"ToCanon", "[", "#", "]"}]}], "]"}], ",", 
               RowBox[{"eTable", "[", 
                RowBox[{"ToCanon", "[", "#", "]"}], "]"}], ",", "Infinity"}], 
              "]"}], "&"}], ",", 
            RowBox[{"(*", 
             RowBox[{
              RowBox[{
               RowBox[{
               "Sort", " ", "by", " ", "wTable", " ", "value", " ", "in", " ",
                 "descending", " ", "order"}], ";", 
               RowBox[{"if", " ", "not", " ", "present"}]}], ",", 
              RowBox[{"assign", "-", 
               RowBox[{
               "Infinity", " ", "to", " ", "place", " ", "at", " ", "the", " ",
                 "end"}]}]}], "*)"}], 
            RowBox[{
             RowBox[{"-", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"KeyExistsQ", "[", 
                 RowBox[{"wTable", ",", 
                  RowBox[{"ToCanon", "[", "#", "]"}]}], "]"}], ",", 
                RowBox[{"wTable", "[", 
                 RowBox[{"ToCanon", "[", "#", "]"}], "]"}], ",", 
                RowBox[{"-", "Infinity"}]}], "]"}]}], "&"}]}], "}"}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Return", " ", "the", " ", "sorted", " ", "group"}], "*)"}], 
       "sortedGroup"}]}], "]"}]}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Sorts", " ", "all", " ", "grouped", " ", "graphs", " ", "based", " ", 
     "on", " ", "eTable", " ", "and", " ", "wTable"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SortGroupedGraphsByew", "[", "graphs_List", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "sortedGroups", "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Apply", " ", "SortSingleGroupUD", " ", "to", " ", "each", " ", 
        "group", " ", "to", " ", "sort", " ", "individual", " ", "groups"}], 
       "*)"}], 
      RowBox[{
       RowBox[{"sortedGroups", "=", 
        RowBox[{"SortSingleGroupUD", "/@", "graphs"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Sort", " ", "the", " ", "groups", " ", "based", " ", "on", " ", 
         "the", " ", "minimum", " ", "eTable", " ", "value", " ", "in", " ", 
         "each", " ", "group", " ", "ascending", " ", "and", " ", "the", " ", 
         "maximum", " ", "wTable", " ", "value", " ", "in", " ", "each", " ", 
         "group", " ", "descending"}], "*)"}], 
       RowBox[{"sortedGroups", "=", 
        RowBox[{"SortBy", "[", 
         RowBox[{"sortedGroups", ",", 
          RowBox[{"{", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{
             "Sort", " ", "by", " ", "the", " ", "minimum", " ", "eTable", " ",
               "value", " ", "in", " ", "ascending", " ", "order"}], ";", 
             RowBox[{
             "assign", " ", "Infinity", " ", "if", " ", "not", " ", 
              "present"}]}], "*)"}], 
           RowBox[{
            RowBox[{
             RowBox[{"Min", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"KeyExistsQ", "[", 
                   RowBox[{"eTable", ",", 
                    RowBox[{"ToCanon", "[", "#", "]"}]}], "]"}], ",", 
                  RowBox[{"eTable", "[", 
                   RowBox[{"ToCanon", "[", "#", "]"}], "]"}], ",", 
                  "Infinity"}], "]"}], "&"}], "/@", "#"}], "]"}], "&"}], ",", 
            
            RowBox[{"(*", 
             RowBox[{
              RowBox[{
              "Sort", " ", "by", " ", "the", " ", "maximum", " ", "wTable", " ",
                "value", " ", "in", " ", "descending", " ", "order"}], ";", 
              RowBox[{"assign", "-", 
               RowBox[{
               "Infinity", " ", "if", " ", "not", " ", "present"}]}]}], 
             "*)"}], 
            RowBox[{
             RowBox[{"-", 
              RowBox[{"Max", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{"KeyExistsQ", "[", 
                    RowBox[{"wTable", ",", 
                    RowBox[{"ToCanon", "[", "#", "]"}]}], "]"}], ",", 
                   RowBox[{"wTable", "[", 
                    RowBox[{"ToCanon", "[", "#", "]"}], "]"}], ",", 
                   RowBox[{"-", "Infinity"}]}], "]"}], "&"}], "/@", "#"}], 
               "]"}]}], "&"}]}], "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Return", " ", "the", " ", "fully", " ", "sorted", " ", "groups", " ",
          "of", " ", "graphs"}], "*)"}], "sortedGroups"}]}], "]"}]}], 
   "\n"}]}]], "Input",
