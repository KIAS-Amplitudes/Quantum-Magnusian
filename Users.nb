Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"CanonicaliseCdGrf", "[", 
     RowBox[{"CdGrf", "[", 
      RowBox[{
       RowBox[{"VList", "[", "]"}], ",", 
       RowBox[{"EList", "[", "]"}]}], "]"}], "]"}], "=", 
    RowBox[{"CdGrf", "[", 
     RowBox[{
      RowBox[{"VList", "[", "]"}], ",", 
      RowBox[{"EList", "[", "]"}]}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "specify", " ", "canonical", " ", "empty", " ", "graph", " ", "directly"}],
    " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CanonicaliseCdGrf", "[", "foo_CdGrf", "]"}], ":=", 
  RowBox[{
   RowBox[{"Catch", "@", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"eval", "=", 
        RowBox[{"foo", "//", "ReorderVertices"}]}], " ", 
       RowBox[{"(*", " ", 
        RowBox[{"preliminary", " ", "renaming"}], " ", "*)"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"Not", "[", 
            RowBox[{
             RowBox[{"{", "}"}], "===", 
             RowBox[{"FindCdGrfIsomorphism", "[", 
              RowBox[{"eval", ",", "#"}], "]"}]}], "]"}], ",", 
           RowBox[{"Throw", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
        "$CanonicalCdGrfList"}], ";", " ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "return", " ", "a", " ", "graph", " ", "in", " ", 
         "$CanonicalCdGrfList", " ", "if", " ", "there", " ", "is", " ", "an",
          " ", "isomorphic", " ", "graph"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"$CanonicalCdGrfList", "=", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"$CanonicalCdGrfList", ",", "eval"}], "}"}], "//", 
         "Flatten"}]}], ";", "\[IndentingNewLine]", "eval"}]}], " ", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
       "if", " ", "no", " ", "graph", " ", "is", " ", "found", " ", "within", 
        " ", "$CanonicalCdGrfList", " ", "that", " ", "is", " ", "isomorphic",
         " ", "to", " ", "the", " ", "input"}], ",", " ", 
       RowBox[{
       "add", " ", "the", " ", "renamed", " ", "graph", " ", "to", " ", 
        "$CanonicalCdGrfList", " ", "and", " ", "return", " ", "the", " ", 
        "renamed", " ", "graph"}]}], " ", "*)"}], "\[IndentingNewLine]", 
     "]"}]}], "//", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"CanonicaliseCdGrf", "[", "#", "]"}], "=", "#"}], ")"}], "&"}], 
   " ", 
   RowBox[{"(*", " ", 
    RowBox[{"save", " ", "canonical", " ", "graphs"}], " ", 
    "*)"}]}]}]}], "Input",
