                RowBox[{
                 RowBox[{"Length", "[", "ex", "]"}], ">", "2"}]}]}]}], 
             "}"}]}], "//", "GroupConnectedEdges"}], ",", "vertlist"}], 
         "]"}]}]}]}], "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Convert", " ", "list", " ", "of", " ", "edge"}], "-", 
      "lists"}], "\[RightArrow]", 
     RowBox[{"CdGrf", " ", 
      RowBox[{"(", 
       RowBox[{"multi", "-", 
        RowBox[{"color", " ", "graph"}]}], ")"}]}]}], "*)"}], 
   RowBox[{
    RowBox[{"ListToCdGrf", "[", "edgelist_List", "]"}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"eval", ",", "vertlist", ",", "colourlist"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"assign", " ", "colors", " ", "c1"}], ",", "c2", ",", 
        RowBox[{
         RowBox[{"...", " ", "to", " ", "each", " ", "sub"}], "-", 
         RowBox[{"edge", " ", "list"}]}]}], "*)"}], 
      RowBox[{
       RowBox[{"colourlist", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"ToExpression", "[", 
            RowBox[{"\"\<$c\>\"", "<>", 
             RowBox[{"ToString", "[", "#", "]"}]}], "]"}], ")"}], "&"}], "/@", 
         RowBox[{"Range", "[", 
          RowBox[{"Length", "[", "edgelist", "]"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "convert", " ", "each", " ", "edge", " ", "list", " ", "into", " ", 
