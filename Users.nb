   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{
     "wCLPath", ",", "WTableRoot", ",", "SafeFileName", ",", "WTablePrefix"}],
      "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"wCLPath", "[", "file_String", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "dir", "}"}], ",", 
       RowBox[{
        RowBox[{"dir", "=", 
         RowBox[{"Quiet", "@", 
          RowBox[{"Check", "[", 
           RowBox[{
            RowBox[{"NotebookDirectory", "[", "]"}], ",", "$Failed"}], 
           "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"dir", "===", "$Failed"}], "||", 
           RowBox[{"dir", "===", "None"}]}], ",", 
          RowBox[{"dir", "=", 
           RowBox[{"Directory", "[", "]"}]}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"dir", ",", "file"}], "}"}], "]"}]}]}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"WTableRoot", "[", "]"}], ":=", 
     RowBox[{"wCLPath", "[", "\"\<OmegaData\>\"", "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"WTablePrefix", "[", "\"\<CL\>\"", "]"}], ":=", "\"\<CL_\>\""}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"WTablePrefix", "[", "\"\<BW\>\"", "]"}], ":=", "\"\<BW_\>\""}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"SafeFileName", "[", "s_", "]"}], ":=", 
     RowBox[{"StringReplace", "[", 
      RowBox[{
       RowBox[{"ToString", "[", 
        RowBox[{"s", ",", "InputForm"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\</\>\"", "->", "\"\<_\>\""}], ",", 
         RowBox[{"\"\<\\\\\>\"", "->", "\"\<_\>\""}], ",", 
         RowBox[{"\"\<:\>\"", "->", "\"\<_\>\""}], ",", 
         RowBox[{"\"\<*\>\"", "->", "\"\<_\>\""}], ",", 
         RowBox[{"\"\<?\>\"", "->", "\"\<_\>\""}], ",", 
         RowBox[{"\"\<\\\"\>\"", "->", "\"\<_\>\""}], ",", 
         RowBox[{"\"\<<\>\"", "->", "\"\<_\>\""}], ",", 
         RowBox[{"\"\<>\>\"", "->", "\"\<_\>\""}], ",", 
         RowBox[{"\"\<|\>\"", "->", "\"\<_\>\""}], ",", 
         RowBox[{"\"\< \>\"", "->", "\"\<\>\""}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"===", 
     RowBox[{"==", "SAVE"}], "===", "===", "===", "===", "===", "===", "===", 
     "===", "===", "===", "===", "===", "===", "===", "=="}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "==="}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{"SaveOneWTable", ",", "SaveWTable"}], "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"SaveOneWTable", "[", 
      RowBox[{"table_Association", ",", "folder_String"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"dir", ",", "prefix", ",", "files"}], "}"}], ",", 
       RowBox[{
        RowBox[{"dir", "=", 
         RowBox[{"FileNameJoin", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"WTableRoot", "[", "]"}], ",", "folder"}], "}"}], "]"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"prefix", "=", 
         RowBox[{"WTablePrefix", "[", "folder", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"DirectoryQ", "[", "dir", "]"}]}], ",", 
          RowBox[{"CreateDirectory", "[", 
           RowBox[{"dir", ",", 
            RowBox[{"CreateIntermediateDirectories", "->", "True"}]}], 
           "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"DirectoryQ", "[", "dir", "]"}], ",", 
          RowBox[{"DeleteFile", "/@", 
           RowBox[{"FileNames", "[", 
            RowBox[{
             RowBox[{"prefix", "<>", "\"\<*.m\>\""}], ",", "dir"}], "]"}]}]}],
          "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"files", "=", 
         RowBox[{"KeyValueMap", "[", 
          RowBox[{
           RowBox[{"Function", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"k", ",", "v"}], "}"}], ",", 
             RowBox[{"Module", "[", 
              RowBox[{
               RowBox[{"{", "path", "}"}], ",", 
               RowBox[{
                RowBox[{"path", "=", 
                 RowBox[{"FileNameJoin", "[", 
                  RowBox[{"{", 
                   RowBox[{"dir", ",", 
                    RowBox[{"prefix", "<>", 
                    RowBox[{"SafeFileName", "[", "k", "]"}], 
                    "<>", "\"\<.m\>\""}]}], "}"}], "]"}]}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"Put", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"k", ",", "v"}], "}"}], ",", "path"}], "]"}], ";", 
                "\[IndentingNewLine]", "path"}]}], "]"}]}], "]"}], ",", 
           "table"}], "]"}]}], ";", "\[IndentingNewLine]", "files"}]}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"SaveWTable", "[", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"clFiles", ",", "bwFiles"}], "}"}], ",", 
       RowBox[{
        RowBox[{"clFiles", "=", 
         RowBox[{"SaveOneWTable", "[", 
          RowBox[{"wCLTable", ",", "\"\<CL\>\""}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"bwFiles", "=", 
         RowBox[{"SaveOneWTable", "[", 
          RowBox[{"wBWTable", ",", "\"\<BW\>\""}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"wCLLoadedFiles", "=", 
         RowBox[{"AssociationThread", "[", 
          RowBox[{"clFiles", ",", 
           RowBox[{"FileByteCount", "/@", "clFiles"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"wBWLoadedFiles", "=", 
         RowBox[{"AssociationThread", "[", 
          RowBox[{"bwFiles", ",", 
           RowBox[{"FileByteCount", "/@", "bwFiles"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"$wStatus", "=", 
         RowBox[{"\"\<Saved : CL \>\"", "<>", 
          RowBox[{"ToString", "[", 
           RowBox[{"Length", "[", "clFiles", "]"}], "]"}], 
          "<>", "\"\< files / BW \>\"", "<>", 
          RowBox[{"ToString", "[", 
           RowBox[{"Length", "[", "bwFiles", "]"}], "]"}], 
          "<>", "\"\< files\>\""}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", "$wStatus", "]"}], ";"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
