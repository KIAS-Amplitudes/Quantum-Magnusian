                  RowBox[{
                   RowBox[{"Length", "[", "ex", "]"}], ">", "2"}]}]}]}], 
               "}"}]}], ",", "colourlist", ",", "EList"}], "]"}], "//", 
           "GroupConnectedCdEdges"}], ",", "vertlist"}], "]"}]}]}]}], "]"}], 
    RowBox[{"(*", 
     RowBox[{"/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"$c1", ":>", "$c2"}], ",", 
        RowBox[{"$c2", ":>", "$c1"}]}], "}"}]}], "*)"}]}]}]}]], "Input",
