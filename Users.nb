Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Recursively", " ", "flips", " ", "edges", " ", "in", " ", "a", " ", 
    "graph", " ", "starting", " ", "from", " ", "the", " ", "root"}], "*)"}], 
  
  RowBox[{
   RowBox[{
    RowBox[{"FlipEdgesRecursively", "[", 
     RowBox[{
     "edges_", ",", "root_", ",", "visited_", ",", 
      "neighborsAWithRootVList_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"flippedEdges", "=", 
         RowBox[{"{", "}"}]}], ",", 
        RowBox[{"flipCount", "=", "0"}], ",", "connectedEdges", ",", 
        "newEdges", ",", "newFlipCount"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{"Outgoing", " ", "edges", " ", "from", " ", "root"}], "*)"}], 
      RowBox[{
       RowBox[{"connectedEdges", "=", 
        RowBox[{"Select", "[", 
         RowBox[{"edges", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "==", "root"}], "&"}]}], "]"}]}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"!", 
            RowBox[{"MemberQ", "[", 
             RowBox[{"visited", ",", 
              RowBox[{"edge", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"(*", 
            RowBox[{
            "Flip", " ", "the", " ", "direction", " ", "of", " ", "the", " ", 
             "edge"}], "*)"}], 
           RowBox[{
            RowBox[{"AppendTo", "[", 
             RowBox[{"flippedEdges", ",", 
              RowBox[{"Edge", "[", 
               RowBox[{
                RowBox[{"edge", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], ",", 
                RowBox[{"edge", "[", 
                 RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"flipCount", "++"}], ";", "\[IndentingNewLine]", 
            RowBox[{"(*", 
             RowBox[{
             "Recursively", " ", "flip", " ", "edges", " ", "from", " ", 
              "the", " ", "connected", " ", "vertex"}], "*)"}], 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"newEdges", ",", "newFlipCount"}], "}"}], "=", 
             RowBox[{"FlipEdgesRecursively", "[", 
              RowBox[{"edges", ",", 
               RowBox[{"edge", "[", 
                RowBox[{"[", "2", "]"}], "]"}], ",", 
               RowBox[{"Append", "[", 
                RowBox[{"visited", ",", 
                 RowBox[{"edge", "[", 
                  RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ",", 
               "neighborsAWithRootVList"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
