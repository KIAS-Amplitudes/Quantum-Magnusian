Cell[BoxData[
 RowBox[{
  RowBox[{"FindCdGrfIsomorphism", "[", 
   RowBox[{"foo_CdGrf", ",", "goo_CdGrf"}], "]"}], ":=", 
  RowBox[{"Catch", "@", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"vertlist1", ",", "vertlist2"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"Or", "[", 
         RowBox[{
          RowBox[{"Not", "[", 
           RowBox[{
            RowBox[{"Length", "[", 
             RowBox[{"foo", "//", "First"}], "]"}], "===", 
            RowBox[{"Length", "[", 
             RowBox[{"goo", "//", "First"}], "]"}]}], "]"}], ",", 
          RowBox[{"Not", "[", 
           RowBox[{
            RowBox[{"Length", "[", 
             RowBox[{"foo", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "]"}], "===", 
            RowBox[{"Length", "[", 
             RowBox[{"goo", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "]"}]}], "]"}], ",", 
        RowBox[{"Throw", "[", 
         RowBox[{"{", "}"}], "]"}]}], "]"}], ";", 
      RowBox[{"(*", " ", 
       RowBox[{
       "check", " ", "if", " ", "number", " ", "of", " ", "vertices", " ", 
        "and", " ", "number", " ", "of", " ", "edges", " ", "match"}], " ", 
       "*)"}], "\[IndentingNewLine]", 
      RowBox[{"vertlist1", "=", 
       RowBox[{"SortCdGrfVertices", "[", "foo", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"vertlist2", "=", 
       RowBox[{"SortCdGrfVertices", "[", "goo", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"Not", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"First", "/@", "vertlist1"}], ")"}], "===", 
          RowBox[{"(", 
           RowBox[{"First", "/@", "vertlist2"}], ")"}]}], "]"}], ",", 
        RowBox[{"Throw", "[", 
         RowBox[{"{", "}"}], "]"}]}], "]"}], ";", " ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "check", " ", "if", " ", "vertex", " ", "types", " ", "match"}], " ", 
       "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"Not", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"Length", "/@", 
            RowBox[{"Last", "/@", "vertlist1"}]}], ")"}], "===", 
          RowBox[{"(", 
           RowBox[{"Length", "/@", 
            RowBox[{"Last", "/@", "vertlist2"}]}], ")"}]}], "]"}], ",", 
        RowBox[{"Throw", "[", 
         RowBox[{"{", "}"}], "]"}]}], "]"}], ";", " ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "check", " ", "if", " ", "there", " ", "are", " ", "same", " ", 
        "number", " ", "of", " ", "vertices", " ", "for", " ", "each", " ", 
        "vertex", " ", "type"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"goo", "==", 
            RowBox[{"(", 
             RowBox[{"foo", "/.", "#"}], ")"}]}], ",", 
           RowBox[{"Throw", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"(", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"Thread", "/@", 
                 RowBox[{"Flatten", "@", 
                  RowBox[{"Outer", "[", 
                   RowBox[{"Rule", ",", 
                    RowBox[{"{", "#1", "}"}], ",", 
                    RowBox[{"Permutations", "@", "#2"}], ",", "1"}], 
                   "]"}]}]}], "&"}], "@@", "#"}], ")"}], "&"}], "/@", 
            "\[IndentingNewLine]", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Inner", "[", 
               RowBox[{"List", ",", "\[IndentingNewLine]", 
                RowBox[{"Last", "/@", "vertlist1"}], "\[IndentingNewLine]", ",",
                 "\[IndentingNewLine]", 
                RowBox[{"Last", "/@", "vertlist2"}], "\[IndentingNewLine]", ",",
                 "\[IndentingNewLine]", "List"}], "]"}], " ", "/.", 
              RowBox[{"VList", "->", "List"}]}], 
             RowBox[{"(*", " ", 
              RowBox[{
               RowBox[{"match", " ", "possible", " ", "vertices"}], ";", " ", 
               
               RowBox[{
                RowBox[{"VList", "[", "]"}], " ", "is", " ", "unnecessary", " ",
                 "after", " ", "this", " ", "step", " ", "so", " ", "rename", 
                " ", "to", " ", 
                RowBox[{"List", "[", "]"}]}]}], " ", "*)"}], ")"}]}], 
           "\[IndentingNewLine]", ")"}], " ", 
          RowBox[{"(*", " ", 
           RowBox[{
           "generate", " ", "possible", " ", "permutation", " ", "rules", " ",
             "for", " ", "each", " ", "vertex", " ", "type"}], " ", "*)"}], 
          "\[IndentingNewLine]", "//", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"DeleteDuplicates", "/@", 
             RowBox[{"Flatten", "/@", 
              RowBox[{"Flatten", "[", 
               RowBox[{
                RowBox[{"Outer", "[", 
                 RowBox[{"List", ",", 
                  RowBox[{"Sequence", "@@", "#"}], ",", "1"}], "]"}], ",", 
                RowBox[{
                 RowBox[{"Length", "[", "#", "]"}], "-", "1"}]}], "]"}]}]}], 
            ")"}], "&"}]}], " ", 
         RowBox[{"(*", " ", 
          RowBox[{"combine", " ", "permutation", " ", "rules"}], " ", "*)"}], 
         "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", ")"}], " ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "when", " ", "an", " ", "isomorphism", " ", "is", " ", "found"}], ",",
         " ", 
        RowBox[{"return", " ", "the", " ", "isomorphism", " ", "rules"}]}], 
       " ", "*)"}], ";", "\[IndentingNewLine]", 
      RowBox[{"{", "}"}]}]}], " ", 
    RowBox[{"(*", " ", 
     RowBox[{"otherwise", " ", "return", " ", "empty", " ", "set"}], " ", 
     "*)"}], "\[IndentingNewLine]", "]"}], " "}]}]], "Input",
 CellChangeTimes->{{3.97808244329191*^9, 3.9780824467899647`*^9}, {
   3.978082478371832*^9, 3.9780825068132477`*^9}, {3.978082640394462*^9, 
