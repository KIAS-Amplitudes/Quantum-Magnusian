Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Recursively", " ", "flips", " ", "edges", " ", "and", " ", "merges", " ", 
    "graphs"}], "*)"}], 
  RowBox[{
   RowBox[{"RecursiveFlipAndMerge", "[", 
    RowBox[{"graph_Grf", ",", "remainingEdges_List"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"flippedGraph", ",", 
       RowBox[{"(*", 
        RowBox[{
        "The", " ", "graph", " ", "after", " ", "flipping", " ", "an", " ", 
         "edge"}], "*)"}], "mergedGraph", ",", 
       RowBox[{"(*", 
        RowBox[{
        "The", " ", "graph", " ", "after", " ", "merging", " ", "vertices"}], 
        "*)"}], "canonicalFlipped", ",", 
       RowBox[{"(*", 
        RowBox[{
        "Canonical", " ", "form", " ", "of", " ", "the", " ", "flipped", " ", 
         "graph"}], "*)"}], "canonicalFlippedreversed", ",", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "Canonical", " ", "form", " ", "of", " ", "the", " ", "edge"}], "-", 
         
         RowBox[{"reversed", " ", "flipped", " ", "graph"}]}], "*)"}], 
       "canonicalMerged", ",", 
       RowBox[{"(*", 
        RowBox[{
        "Canonical", " ", "form", " ", "of", " ", "the", " ", "merged", " ", 
         "graph"}], "*)"}], "result", ",", 
       RowBox[{"(*", 
        RowBox[{"Intermediate", " ", "result", " ", "for", " ", "wTable"}], 
        "*)"}], "eresult"}], "                      ", 
      RowBox[{"(*", 
       RowBox[{"Intermediate", " ", "result", " ", "for", " ", "eTable"}], 
       "*)"}], "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{
      "If", " ", "there", " ", "are", " ", "no", " ", "remaining", " ", 
       "edges", " ", "to", " ", "process"}], "*)"}], 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"remainingEdges", "===", 
         RowBox[{"{", "}"}]}], ",", 
        RowBox[{"(", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{
           "Check", " ", "if", " ", "the", " ", "canonical", " ", "form", " ",
             "of", " ", "the", " ", "graph", " ", "or", " ", "its", " ", 
            "edge"}], "-", 
           RowBox[{
           "reversed", " ", "version", " ", "is", " ", "not", " ", "already", 
            " ", "in", " ", "SetGraphTable"}]}], "*)"}], 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"!", 
              RowBox[{"KeyExistsQ", "[", 
               RowBox[{"SetGraphTable", ",", 
                RowBox[{"ToCanon", "[", 
                 RowBox[{"ReverseAllEdges", "[", "graph", "]"}], "]"}]}], 
               "]"}]}], "&&", 
             RowBox[{"!", 
              RowBox[{"KeyExistsQ", "[", 
               RowBox[{"SetGraphTable", ",", 
                RowBox[{"ToCanon", "[", "graph", "]"}]}], "]"}]}]}], ",", 
            RowBox[{"(", 
             RowBox[{"(*", 
              RowBox[{
              "Add", " ", "the", " ", "graph", " ", "to", " ", "the", " ", 
               "collected", " ", "graphs", " ", "set"}], "*)"}], 
             RowBox[{
              RowBox[{"addGraphToSet", "[", "graph", "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
               "Mark", " ", "the", " ", "canonical", " ", "form", " ", "of", " ",
                 "the", " ", "graph", " ", "as", " ", "processed", " ", "in", 
                " ", "SetGraphTable"}], "*)"}], 
              RowBox[{
               RowBox[{"SetGraphTable", "[", 
                RowBox[{"ToCanon", "[", "graph", "]"}], "]"}], "=", "0"}], 
              ";"}], ")"}]}], "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Terminate", " ", "recursion", " ", "and", " ", "return", " ", 
            "the", " ", "current", " ", "graph"}], "*)"}], 
          RowBox[{"Return", "[", "graph", "]"}], ";"}], ")"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Flip", " ", "the", " ", "first", " ", "edge", " ", "in", " ", "the", " ",
         "list", " ", "of", " ", "remaining", " ", "edges"}], "*)"}], 
      RowBox[{"flippedGraph", "=", 
       RowBox[{"FlipEdge", "[", 
        RowBox[{"graph", ",", 
         RowBox[{"First", "[", "remainingEdges", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Obtain", " ", "the", " ", "canonical", " ", "form", " ", "of", " ", 
        "the", " ", "flipped", " ", "graph"}], "*)"}], 
      RowBox[{"canonicalFlipped", "=", 
       RowBox[{"ToCanon", "[", "flippedGraph", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Check", " ", "if", " ", "the", " ", "flipped", " ", 
        RowBox[{"graph", "'"}], "s", " ", "canonical", " ", "form", " ", "is",
         " ", "not", " ", "already", " ", "in", " ", "wTable"}], "*)"}], 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"KeyExistsQ", "[", 
          RowBox[{"wTable", ",", "canonicalFlipped"}], "]"}]}], ",", 
        RowBox[{"(", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{
           "Obtain", " ", "the", " ", "canonical", " ", "form", " ", "of", " ",
             "the", " ", "edge"}], "-", 
           RowBox[{"reversed", " ", "flipped", " ", "graph"}]}], "*)"}], 
         RowBox[{
          RowBox[{"canonicalFlippedreversed", "=", 
           RowBox[{"ToCanon", "[", 
            RowBox[{"ReverseAllEdges", "[", "flippedGraph", "]"}], "]"}]}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"Check", " ", "if", " ", "the", " ", "edge"}], "-", 
            RowBox[{"reversed", " ", "flipped", " ", 
             RowBox[{"graph", "'"}], "s", " ", "canonical", " ", "form", " ", 
             "is", " ", "also", " ", "not", " ", "in", " ", "wTable"}]}], 
           "*)"}], 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"KeyExistsQ", "[", 
              RowBox[{"wTable", ",", "canonicalFlippedreversed"}], "]"}]}], ",", 
            RowBox[{"(", 
             RowBox[{"(*", 
              RowBox[{
              "Merge", " ", "the", " ", "graph", " ", "by", " ", "removing", " ",
                "the", " ", "flipped", " ", "edge"}], "*)"}], 
             RowBox[{
              RowBox[{"mergedGraph", "=", 
               RowBox[{"MergeGraph", "[", 
                RowBox[{"graph", ",", 
                 RowBox[{"First", "[", "remainingEdges", "]"}]}], "]"}]}], ";",
               "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
               "Obtain", " ", "the", " ", "canonical", " ", "form", " ", "of",
                 " ", "the", " ", "merged", " ", "graph"}], "*)"}], 
              RowBox[{"canonicalMerged", "=", 
               RowBox[{"ToCanon", "[", "mergedGraph", "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
               "Calculate", " ", "the", " ", "new", " ", "wTable", " ", 
                "value"}], "*)"}], 
              RowBox[{"result", "=", 
               RowBox[{
                RowBox[{"-", 
                 RowBox[{"wTable", "[", "canonicalMerged", "]"}]}], "-", 
                RowBox[{"wTable", "[", 
                 RowBox[{"ToCanon", "[", "graph", "]"}], "]"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
               "Calculate", " ", "the", " ", "new", " ", "eTable", " ", 
                "value"}], "*)"}], 
              RowBox[{"eresult", "=", 
               RowBox[{
                RowBox[{"ComputeEProductAfterSplit", "[", 
                 RowBox[{"graph", ",", 
                  RowBox[{"First", "[", "remainingEdges", "]"}]}], "]"}], "-", 
                RowBox[{"eTable", "[", 
                 RowBox[{"ToCanon", "[", "graph", "]"}], "]"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
                RowBox[{
                "Update", " ", "wTable", " ", "with", " ", "the", " ", "new", 
                 " ", "result", " ", "for", " ", "both", " ", "flipped", " ", 
                 "and", " ", "edge"}], "-", 
                RowBox[{"reversed", " ", "flipped", " ", "graphs"}]}], "*)"}], 
              RowBox[{
               RowBox[{"wTable", "[", "canonicalFlipped", "]"}], "=", 
               "result"}], ";", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"wTable", "[", "canonicalFlippedreversed", "]"}], "=", 
               "result"}], ";", "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
                RowBox[{
                "Update", " ", "eTable", " ", "with", " ", "the", " ", "new", 
                 " ", "eresult", " ", "for", " ", "both", " ", "flipped", " ",
                  "and", " ", "edge"}], "-", 
                RowBox[{"reversed", " ", "flipped", " ", "graphs"}]}], "*)"}], 
              RowBox[{
               RowBox[{"eTable", "[", "canonicalFlipped", "]"}], "=", 
               "eresult"}], ";", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"eTable", "[", "canonicalFlippedreversed", "]"}], "=", 
               "eresult"}], ";"}], ")"}], ",", 
            RowBox[{"(", 
             RowBox[{"(*", 
              RowBox[{
               RowBox[{
                RowBox[{"If", " ", "the", " ", "edge"}], "-", 
                RowBox[{
                "reversed", " ", "flipped", " ", "graph", " ", "already", " ",
                  "exists", " ", "in", " ", "wTable"}]}], ",", 
               RowBox[{
               "set", " ", "wTable", " ", "and", " ", "eTable", " ", 
                "accordingly"}]}], "*)"}], 
             RowBox[{
              RowBox[{
               RowBox[{"wTable", "[", "canonicalFlipped", "]"}], "=", 
               RowBox[{"wTable", "[", "canonicalFlippedreversed", "]"}]}], ";",
               "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"eTable", "[", "canonicalFlipped", "]"}], "=", 
               RowBox[{"eTable", "[", "canonicalFlippedreversed", "]"}]}], 
              ";"}], ")"}]}], "]"}]}], ")"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Recursive", " ", "call", " ", "with", " ", "the", " ", "flipped", " ",
         "graph", " ", "and", " ", "the", " ", "rest", " ", "of", " ", "the", 
        " ", "edges"}], "*)"}], 
      RowBox[{"RecursiveFlipAndMerge", "[", 
       RowBox[{"flippedGraph", ",", 
        RowBox[{"Rest", "[", "remainingEdges", "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Recursive", " ", "call", " ", "with", " ", "the", " ", "original", " ",
         "graph", " ", "and", " ", "the", " ", "rest", " ", "of", " ", "the", 
        " ", "edges"}], "*)"}], 
      RowBox[{"RecursiveFlipAndMerge", "[", 
       RowBox[{"graph", ",", 
        RowBox[{"Rest", "[", "remainingEdges", "]"}]}], "]"}], ";"}]}], 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9365052817444267`*^9, 3.936505281747059*^9}, {
