Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"CanonicaliseGrf", "[", 
     RowBox[{"Grf", "[", 
      RowBox[{
       RowBox[{"VList", "[", "]"}], ",", 
       RowBox[{"EList", "[", "]"}]}], "]"}], "]"}], "=", 
    RowBox[{"Grf", "[", 
     RowBox[{
      RowBox[{"VList", "[", "]"}], ",", 
      RowBox[{"EList", "[", "]"}]}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "specify", " ", "canonical", " ", "empty", " ", "graph", " ", "directly"}],
    " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CanonicaliseGrf", "[", "foo_Grf", "]"}], ":=", 
  RowBox[{"Catch", "[", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"eval", ",", "vertlist"}], "}"}], ",", 
     RowBox[{
      RowBox[{"eval", "=", 
       RowBox[{"foo", "/.", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"foo", "//", "Grf2MMCGraphOrigin"}], "//", 
              RowBox[{
               RowBox[{"FindGraphIsomorphism", "[", 
                RowBox[{"#", ",", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"CanonicalGraph", "[", "#", "]"}], "//", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Head", "[", "#", "]"}], "===", "Graph"}], ",", 
                    "#", ",", 
                    RowBox[{
                    RowBox[{
                    "Print", 
                    "[", "\"\<Error: could not canonicalise using \
Mathematica's built-in CanonicalGraph\>\"", "]"}], ";", 
                    RowBox[{"Throw", "[", "foo", "]"}]}]}], "]"}], "&"}], 
                    ")"}]}], ")"}]}], "]"}], "&"}]}], "//", "First"}], "//", 
            "Normal"}], ")"}], "/.", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Rule", "[", 
             RowBox[{"ex1_", ",", "ex2_"}], "]"}], ":>", 
            RowBox[{"Rule", "[", 
             RowBox[{"ex1", ",", 
              RowBox[{"VT", "[", "ex2", "]"}]}], "]"}]}], "}"}]}], ")"}]}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"vertlist", "=", 
       RowBox[{
        RowBox[{"Cases", "[", 
         RowBox[{
          RowBox[{"eval", "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", "_VT", ",", "All"}], "]"}], "//",
         "Flatten"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"vertlist", "=", 
       RowBox[{"Thread", "[", 
        RowBox[{"Rule", "[", 
         RowBox[{"vertlist", ",", 
          RowBox[{"VT", "/@", 
           RowBox[{"Range", "[", 
            RowBox[{"Length", "@", "vertlist"}], "]"}]}]}], "]"}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"eval", "/.", "vertlist"}], ")"}], "//", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"CanonicaliseGrf", "[", "#", "]"}], "=", "#"}], ")"}], 
        "&"}]}]}]}], " ", 
    RowBox[{"(*", " ", 
     RowBox[{"save", " ", "canonical", " ", "graphs"}], " ", "*)"}], 
    "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", "]"}]}]}], "Input",
 CellLabel->
  "In[437]:=",ExpressionUUID->"3d8fd9f4-2e4f-4226-a8d4-bd79abee2106"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CanonicaliseCdGrfSingleColour", "[", 
   RowBox[{"foo_CdGrf", ",", "colour_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{"foo", "/.", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"foo", "/.", 
             RowBox[{"{", 
              RowBox[{"ex_CdEdge", ":>", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"colour", "===", 
                  RowBox[{"Last", "[", "ex", "]"}]}], ",", "ex", ",", 
                 "Nothing"}], "]"}]}], "}"}]}], ")"}], "//", 
           "CdGrf2MMCGraph"}], "//", 
          RowBox[{
           RowBox[{"FindGraphIsomorphism", "[", 
            RowBox[{"#", ",", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"CanonicalGraph", "[", "#", "]"}], "//", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"Head", "[", "#", "]"}], "===", "Graph"}], ",", 
                   "#", ",", 
                   RowBox[{
                    RowBox[{
                    "Print", 
                    "[", "\"\<Error: could not canonicalise using \
Mathematica's built-in CanonicalGraph\>\"", "]"}], ";", 
                    RowBox[{"Throw", "[", "foo", "]"}]}]}], "]"}], "&"}], 
                ")"}]}], ")"}]}], "]"}], "&"}]}], "//", "First"}], "//", 
